# Copy to .env — DEMO_MODE=true runs everything locally with mocked GCP clients.
DEMO_MODE=true
ENV=development
JWT_SECRET=dev-only-change-me

# Real AI + live data (both optional; graceful fallback when absent)
GEMINI_API_KEY=            # Google AI key -> real Gemini even in demo mode
GEMINI_API_MODEL=gemini-3.5-flash
LIVE_WEATHER=true          # Open-Meteo live weather (no key needed)

# Production (DEMO_MODE=false) — requires Application Default Credentials
GCP_PROJECT_ID=sentinel-ai-hackathon
GCP_REGION=us-central1
GEMINI_MODEL=gemini-2.5-pro
BQ_DATASET=sentinel_ai
GCS_BUCKET=sentinel-ai-data
VECTOR_INDEX_ID=
VECTOR_INDEX_ENDPOINT_ID=
DOCAI_PROCESSOR_ID=
GOOGLE_MAPS_API_KEY=
ALLOYDB_URI=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
